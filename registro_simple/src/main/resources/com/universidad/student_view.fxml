<!-- 
Es necesario que la clase controladora este en el paquete especificado fx:controller="com.universidad.StudentController"
Es muy importante que los id de los controles concuerde con los de la Clase Controladora
Debes reevisar tambien que en onAction="#handleRegistrar" este correctamente el nombre del método adecuadoa para la tarea especifica
-->


<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1"  fx:controller="com.universidad.controllers.StudentController">
