<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.SaludoController"
      alignment="CENTER"
      spacing="15">

    <padding>
        <Insets top="20"
                right="20"
                bottom="20"
                left="20"/>
    </padding>

    <Label text="Saludo"/>

    <Label fx:id="lblSaludo"/>

    <Button text="Regresar"
            onAction="#regresar"/>

</VBox>
